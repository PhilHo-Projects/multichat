# Copy this to .env for local experiments, or set the same names in PM2/AWS.
# Never commit a real .env file.

GOOGLE_API_KEY=
NVIDIA_API_KEY=

# google or nvidia
DEFAULT_PROVIDER=nvidia
DEFAULT_MODEL=deepseek-ai/deepseek-v4-pro
DEFAULT_SYSTEM_PROMPT=You are a helpful AI assistant. Answer clearly and concisely. If you are unsure, say so.

# Deployment path/port. Local dev can leave these blank.
APP_BASE_PATH=/philchat
PORT=8791
VITE_BASE_PATH=/philchat/

# Optional: Google Cloud Monitoring quota dashboard
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_QUOTA_LOOKBACK_HOURS=24
